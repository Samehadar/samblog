---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { type Locale } from "../consts";

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  contentLocale?: Locale;
  ogImage?: string;
  post?: {
    date: Date;
    tags?: string[];
  };
  localeLinks?: Partial<Record<Locale, string>>;
}

const { title, description, locale, contentLocale, ogImage, post, localeLinks } = Astro.props;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
---

<html lang={contentLocale || locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/fonts/cambria/regular.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/fonts/cambria/bold.woff2`} as="font" type="font/woff2" crossorigin />
    <SEO title={title} description={description} locale={locale} ogImage={ogImage} post={post} />
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        if (t === "light") return;
        if (t === "dark") { document.documentElement.classList.add("dark"); return; }
        if (window.matchMedia("(prefers-color-scheme: light)").matches) return;
        document.documentElement.classList.add("dark");
      })();
    </script>
    {umamiId && (
      <script defer src="https://cloud.umami.is/script.js" data-website-id={umamiId} />
    )}
  </head>
  <body>
    <Header locale={locale} currentPath={Astro.url.pathname} localeLinks={localeLinks} />

    <main class="main-content">
      <slot name="header" />
      <slot />
    </main>

    <Footer locale={locale} />

    <script>
      document.querySelectorAll('a[href^="http"]').forEach((a) => {
        if (!a.href.startsWith(window.location.origin)) {
          a.classList.add("external");
        }
      });
    </script>
  </body>
</html>

<style>
  .main-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    min-height: calc(100vh - 3.5rem - 8rem);
  }

  @media (max-width: 640px) {
    .main-content {
      padding: 2rem 1rem;
    }
  }
</style>
