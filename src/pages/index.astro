---
import { SITE } from "../consts";

const ogImage = new URL("/images/og-default.png", SITE.domain).href;
const description = `${SITE.author.en} — CTO, engineer and mentor writing about engineering leadership, scaling teams, architecture decisions and lessons learned along the way.`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Vitaly Lyutarevich — Engineering & Technology</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Vitaly Lyutarevich — Engineering & Technology" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE.domain} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Vitaly Lyutarevich — Engineering & Technology" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={`${SITE.domain}/en/`} />
    <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
      (function() {
        var b = base.endsWith("/") ? base : base + "/";
        var supported = ["ru", "en", "pl"];
        var saved = localStorage.getItem("locale");
        if (saved && supported.indexOf(saved) !== -1) {
          window.location.replace(b + saved + "/");
          return;
        }
        var langs = navigator.languages || [navigator.language || "en"];
        for (var i = 0; i < langs.length; i++) {
          var code = langs[i].split("-")[0].toLowerCase();
          if (supported.indexOf(code) !== -1) {
            window.location.replace(b + code + "/");
            return;
          }
        }
        window.location.replace(b + "en/");
      })();
    </script>
    <meta http-equiv="refresh" content="0;url=en/" />
  </head>
  <body></body>
</html>
