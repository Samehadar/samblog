---

<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
      (function() {
        var b = base.endsWith("/") ? base : base + "/";
        var supported = ["ru", "en", "pl"];
        var saved = localStorage.getItem("locale");
        if (saved && supported.indexOf(saved) !== -1) {
          window.location.replace(b + saved + "/");
          return;
        }
        var langs = navigator.languages || [navigator.language || "en"];
        for (var i = 0; i < langs.length; i++) {
          var code = langs[i].split("-")[0].toLowerCase();
          if (supported.indexOf(code) !== -1) {
            window.location.replace(b + code + "/");
            return;
          }
        }
        window.location.replace(b + "en/");
      })();
    </script>
    <meta http-equiv="refresh" content="0;url=en/" />
  </head>
  <body></body>
</html>
