---
import Base from "../../../layouts/Base.astro";
import BlogFilter from "../../../components/BlogFilter.vue";
import { getCollection } from "astro:content";
import { locales, type Locale } from "../../../consts";
import { useTranslations, getLocalePath } from "../../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);

const allPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const postsForFilter = allPosts.map((post) => ({
  slug: post.id,
  title: post.data.title,
  date: post.data.date.toISOString(),
  locale: post.data.locale,
  tags: post.data.tags,
  description: post.data.description,
  readingTime: post.data.readingTime as number,
  habr: post.data.habr,
  video: post.data.video,
  href: getLocalePath(locale, `blog/${post.id}`),
}));

const languages = [...new Set(allPosts.map((p) => p.data.locale))].sort();
---

<Base title={t("blog.title")} locale={locale}>
  <div class="blog-page">
    <h1 class="blog-heading">{t("blog.title")}</h1>

    <BlogFilter
      client:load
      posts={postsForFilter}
      languages={languages}
      allLanguagesLabel={t("blog.allLanguages")}
      allTagsLabel={t("blog.allTags")}
      noResultsLabel={t("blog.noResults")}
      readingTimeLabel={t("blog.readingTime")}
      pageLocale={locale}
    />
  </div>
</Base>

<style>
  .blog-page {
    max-width: 680px;
    margin: 0 auto;
  }

  .blog-heading {
    font-family: var(--font-serif);
    font-size: 2.5586rem;
    font-weight: bold;
    line-height: 1;
    margin: 1rem 0 1.5rem;
    color: var(--color-text);
  }
</style>
