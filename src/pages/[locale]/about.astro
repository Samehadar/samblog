---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { locales, type Locale } from "../../consts";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((l) => ({ params: { locale: l } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const cvLang = locale === "ru" ? "ru" : "en";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const pages = await getCollection("pages");
const aboutPage = pages.find(
  (p) => p.id.startsWith("about") && p.data.locale === locale
);
const Content = aboutPage ? (await render(aboutPage)).Content : null;
---

<Base title={t("about.title")} locale={locale}>
  <div class="about-page">
    <div class="about-photo-wrap">
      <img
        src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/images/photo.png`}
        alt="Vitaly Lyutarevich"
        class="about-photo"
        width="160"
        height="160"
        loading="eager"
      />
    </div>
    <h1 class="page-heading">{t("about.title")}</h1>
    {Content ? (
      <div class="prose">
        <Content />
      </div>
    ) : (
      <p>Content not found.</p>
    )}
    <div class="cv-download">
      <a
        href={`${base}/papers/cv-${cvLang}.pdf`}
        target="_blank"
        rel="noopener noreferrer"
        class="cv-link"
      >
        {t("about.downloadCV")}
      </a>
    </div>
  </div>
</Base>

<style>
  .about-page {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-photo-wrap {
    display: block;
    margin: 1.5rem auto 1rem;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-accent);
  }

  .about-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    transform: scale(1.25);
    filter: grayscale(80%) sepia(20%);
    transition: filter 0.3s ease;
  }

  .about-photo:hover {
    filter: none;
  }

  .cv-download {
    margin-top: 2rem;
    text-align: center;
  }

  .cv-link {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-accent);
    border: 1.5px solid var(--color-accent);
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .cv-link:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .page-heading {
    font-family: var(--font-serif);
    font-size: 2.5586rem;
    font-weight: bold;
    line-height: 1;
    margin: 0 0 1.5rem;
    color: var(--color-text);
    text-align: center;
  }
</style>
