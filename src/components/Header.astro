---
import { SITE, type Locale, locales } from "../consts";
import { useTranslations, getLocalePath, switchLocalePath } from "../i18n/utils";

interface Props {
  locale: Locale;
  currentPath: string;
  localeLinks?: Partial<Record<Locale, string>>;
}

const { locale, currentPath, localeLinks } = Astro.props;
const t = useTranslations(locale);
const author = SITE.author[locale];

const navItems = [
  { label: t("nav.blog"), href: getLocalePath(locale, "blog") },
  { label: t("nav.about"), href: getLocalePath(locale, "about") },
  { label: t("nav.now"), href: getLocalePath(locale, "now") },
  { label: t("nav.mentorship"), href: getLocalePath(locale, "mentorship") },
  { label: t("nav.things"), href: getLocalePath(locale, "things") },
  { label: t("nav.timer"), href: getLocalePath(locale, "timer") },
];

function isActive(href: string) {
  if (href.endsWith("/")) return currentPath === href || currentPath === href.slice(0, -1);
  return currentPath === href || currentPath === href + "/";
}

function localeHref(l: Locale) {
  if (localeLinks?.[l]) return localeLinks[l];
  return switchLocalePath(Astro.url, l);
}
---

<header class="site-header">
  <div class="header-inner">
    <a href={getLocalePath(locale)} class="site-logo">
      <span class="logo-block" aria-hidden="true">V</span>
      <span class="logo-text">{author}</span>
    </a>

    <nav class="desktop-nav">
      {navItems.map((item) => (
        <a href={item.href} class:list={["nav-link", { active: isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <div class="locale-switcher">
        {locales.map((l) => (
          <a
            href={localeHref(l)}
            class:list={["locale-link", { current: l === locale }]}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </div>

      <button id="theme-toggle" type="button" aria-label="Toggle theme" class="theme-btn">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button id="mobile-menu-toggle" type="button" aria-label="Menu" class="mobile-menu-btn">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav">
    {navItems.map((item) => (
      <a href={item.href} class:list={["mobile-nav-link", { active: isActive(item.href) }]}>
        {item.label}
      </a>
    ))}
    <div class="mobile-locale-row">
      {locales.map((l) => (
        <a
          href={localeHref(l)}
          class:list={["locale-link", { current: l === locale }]}
        >
          {l.toUpperCase()}
        </a>
      ))}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-alt);
    border-bottom: 2px solid var(--color-accent);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(8px);
    overflow: visible;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .site-logo:hover { text-decoration: none; }
  .site-logo:hover .logo-text { color: var(--color-accent); }
  .site-logo:hover .logo-block {
    transform: translateY(3px);
    transition: transform 0.2s ease;
  }

  .logo-block {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 5.75rem;
    background-color: #b5532a;
    color: #ffffff;
    font-family: "Georgia", "Times New Roman", serif;
    font-weight: 700;
    font-size: 1.6rem;
    letter-spacing: 0.05em;
    line-height: 1;
    text-align: center;
    padding-top: 0.15em;
    border-radius: 0 0 6px 6px;
    align-self: flex-start;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .desktop-nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav-link:hover { color: var(--color-text); background-color: var(--color-bg-alt); text-decoration: none; }
  .nav-link.active { color: var(--color-accent); }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .locale-switcher {
    display: flex;
    gap: 0.125rem;
    background-color: var(--color-bg-alt);
    border-radius: 6px;
    padding: 0.125rem;
  }

  .locale-link {
    font-family: var(--font-serif);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .locale-link:hover { color: var(--color-text); text-decoration: none; }
  .locale-link.current {
    color: var(--color-accent);
    background-color: var(--color-bg-card);
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
  }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .theme-btn:hover { color: var(--color-text); border-color: var(--color-border-hover); }

  html:not(.dark) .icon-moon { display: none; }
  html.dark .icon-sun { display: none; }

  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-nav.open { display: flex; }

  .mobile-nav-link {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-nav-link:hover { color: var(--color-text); text-decoration: none; }
  .mobile-nav-link.active { color: var(--color-accent); }

  .mobile-locale-row {
    display: flex;
    gap: 0.5rem;
    padding-top: 0.75rem;
  }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .locale-switcher { display: none; }
    .mobile-menu-btn { display: flex; }
    .header-inner { padding: 0 1rem; }
    .mobile-nav { padding: 0.5rem 1rem 1rem; }
    .logo-block {
      width: 2.75rem;
      height: 4.75rem;
      font-size: 1.65rem;
    }
    .logo-text { font-size: 0.95rem; }
  }
</style>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const nav = document.getElementById("mobile-nav");
  if (toggle && nav) {
    toggle.addEventListener("click", () => nav.classList.toggle("open"));
  }

  const themeBtn = document.getElementById("theme-toggle");
  if (themeBtn) {
    themeBtn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }

  document.querySelectorAll(".locale-link").forEach((link) => {
    link.addEventListener("click", () => {
      const locale = link.textContent?.trim().toLowerCase();
      if (locale) localStorage.setItem("locale", locale);
    });
  });
</script>
