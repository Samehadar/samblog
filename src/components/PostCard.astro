---
import type { Locale } from "../consts";
import { useTranslations } from "../i18n/utils";

interface Props {
  title: string;
  slug: string;
  date: Date;
  locale: Locale;
  pageLocale: Locale;
  description?: string;
  tags?: string[];
  readingTime?: number;
}

const { title, slug, date, locale, pageLocale, description, tags, readingTime } = Astro.props;
const t = useTranslations(pageLocale);
const href = `/${pageLocale}/blog/${slug}`;
const dateStr = date.toLocaleDateString(pageLocale, { year: "numeric", month: "short", day: "numeric" });
---

<a href={href} class="post-card">
  <div class="post-card-meta">
    <time datetime={date.toISOString()}>{dateStr}</time>
    {readingTime && <span>&middot; {readingTime} {t("blog.readingTime")}</span>}
    <span class:list={["lang-badge", `lang-${locale}`]}>{locale.toUpperCase()}</span>
  </div>
  <h3 class="post-card-title">{title}</h3>
  {description && <p class="post-card-excerpt">{description}</p>}
  {tags && tags.length > 0 && (
    <div class="post-card-tags">
      {tags.map((tag) => <span class="tag">#{tag}</span>)}
    </div>
  )}
</a>

<style>
  .post-card {
    display: block;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .post-card:hover { text-decoration: none; }
  .post-card:hover .post-card-title { color: var(--color-accent); }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.087rem;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .lang-badge {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.1em 0.4em;
    border-radius: 3px;
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
  }
  .lang-badge.lang-ru { color: #3b82f6; }
  .lang-badge.lang-en { color: #10b981; }
  .lang-badge.lang-pl { color: #f43f5e; }

  .post-card-title {
    font-family: var(--font-serif);
    font-weight: bold;
    font-size: 1.4rem;
    color: var(--color-text);
    margin: 0 0 0.25rem;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-card-excerpt {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .tag {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--color-text-faint);
    background-color: var(--color-bg-alt);
    padding: 0.15em 0.5em;
    border-radius: 4px;
  }
</style>
