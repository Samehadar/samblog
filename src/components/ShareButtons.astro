---
import { SITE, type Locale } from "../consts";
import { useTranslations } from "../i18n/utils";

interface Props {
  title: string;
  url: string;
  locale: Locale;
}

const { title, url, locale } = Astro.props;
const t = useTranslations(locale);
const fullUrl = new URL(url, SITE.domain).href;
const encodedUrl = encodeURIComponent(fullUrl);
const encodedTitle = encodeURIComponent(title);

const telegramUrl = `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const twitterUrl = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
---

<div class="share-buttons">
  <span class="share-label">{t("share.title")}:</span>
  <a href={telegramUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-telegram" title="Telegram">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
  </a>
  <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-linkedin" title="LinkedIn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
  </a>
  <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-twitter" title="X / Twitter">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
  </a>
  <button class="share-btn copy-btn share-copy" title={t("share.copy")} data-url={fullUrl} data-copied-text={t("share.copied")}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
  </button>
</div>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .share-label {
    font-family: var(--font-serif);
    font-size: 1.087rem;
    color: var(--color-text-muted);
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .share-btn:hover {
    border-color: var(--color-border-hover);
    text-decoration: none;
  }

  .share-telegram:hover { color: #26a5e4; border-color: #26a5e4; }
  .share-linkedin:hover { color: #0a66c2; border-color: #0a66c2; }
  .share-twitter:hover { color: #000000; border-color: #000000; }
  html.dark .share-twitter:hover { color: #ffffff; border-color: #ffffff; }
  .share-copy:hover { color: var(--color-accent); border-color: var(--color-accent); }
</style>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = (btn as HTMLElement).dataset.url;
      const copiedText = (btn as HTMLElement).dataset.copiedText;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const svg = btn.querySelector("svg");
        if (svg && copiedText) {
          svg.style.display = "none";
          const span = document.createElement("span");
          span.textContent = copiedText;
          span.style.fontSize = "0.75rem";
          btn.appendChild(span);
          setTimeout(() => {
            span.remove();
            svg.style.display = "";
          }, 2000);
        }
      } catch {}
    });
  });
</script>
